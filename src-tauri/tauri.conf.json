{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeSearch",
  "version": "0.1.0",
  "identifier": "com.codesearch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeSearch",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "© 2026 CodeSearch",
    "category": "DeveloperTool",
    "shortDescription": "ローカルコード全文検索ツール",
    "longDescription": "CodeSearch は Tauri + Tantivy によるローカルコード全文検索ツールです。高速なインデックス検索・シンタックスハイライト・ブックマーク・ハイライトワード機能を提供します。",
    "windows": {
      "wix": {
        "language": "ja-JP"
      },
      "nsis": {
        "languages": ["Japanese"],
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "dialog": {}
  }
}
